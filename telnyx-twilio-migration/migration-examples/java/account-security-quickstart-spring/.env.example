# Authy/Twilio Account Security API (kept on Twilio - no Telnyx equivalent)
# You can get/create one here: https://www.twilio.com/console/authy/applications
export ACCOUNT_SECURITY_API_KEY=ENTER_SECRET_HERE

# Twilio API credentials (kept for Authy)
# (find here https://www.twilio.com/console)
export TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
export TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio Verification Service SID (legacy - replaced by Telnyx below)
export TWILIO_VERIFICATION_SID=VAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telnyx API credentials for Verify
# Get your API key at: https://portal.telnyx.com/#/app/api-keys
export TELNYX_API_KEY=YOUR_TELNYX_API_KEY_HERE

# Telnyx Verify Profile ID
# Create one at: https://portal.telnyx.com/#/app/verify-profiles
export TELNYX_VERIFY_PROFILE_ID=YOUR_VERIFY_PROFILE_ID_HERE
