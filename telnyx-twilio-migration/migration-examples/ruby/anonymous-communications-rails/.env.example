# Your Twilio Account SID. Get a free account at twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_SID
# Your Twilio Auth Token. You can get it at twilio.com/console
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# The Twilio phone number you want to use to send SMS. Get one in the Twilio Console
TWILIO_NUMBER=your_twilio_phone_number
# Application SID. Create a new one: https://www.twilio.com/console/voice/dev-tools/twiml-apps
ANONYMOUS_APPLICATION_SID=your_application_sid

# Telnyx Configuration
# Your Telnyx API Key v2 from https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=your_telnyx_api_key
# Your Telnyx phone number (E.164 format, e.g., +15551234567)
TELNYX_PHONE_NUMBER=your_telnyx_phone_number
# Telnyx Connection ID for TeXML/Call Control applications
TELNYX_CONNECTION_ID=your_telnyx_connection_id
# Telnyx Messaging Profile ID for SMS routing
TELNYX_MESSAGING_PROFILE_ID=your_telnyx_messaging_profile_id
