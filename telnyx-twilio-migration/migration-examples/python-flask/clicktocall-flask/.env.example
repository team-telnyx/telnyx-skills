# Telnyx API credentials
# Generate your API key at https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=YOUR_TELNYX_API_KEY

# Your Telnyx phone number in E.164 format
# You can get a number at https://portal.telnyx.com/#/app/numbers
TELNYX_CALLER_ID=+15551234567

# Optional: Your TeXML Application Connection ID (for outbound calls with TeXML)
# Create at https://portal.telnyx.com/#/app/voice/texml
TELNYX_CONNECTION_ID=YOUR_TEXML_CONNECTION_ID

# Optional: For webhook signature verification
# Get your public key at https://portal.telnyx.com/#/app/account/public-key
TELNYX_PUBLIC_KEY=YOUR_TELNYX_PUBLIC_KEY
