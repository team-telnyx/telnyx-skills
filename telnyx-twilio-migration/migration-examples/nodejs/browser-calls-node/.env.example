# Telnyx API Key
# Get from https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=KEYxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Telnyx phone number in E.164 format
TELNYX_PHONE_NUMBER=+1XXXYYYZZZZ

# SIP Connection ID for WebRTC
# Create at https://portal.telnyx.com/#/app/connections
# Enable WebRTC on the connection
TELNYX_CONNECTION_ID=2695736746993256422

# Port for the application
PORT=3000
