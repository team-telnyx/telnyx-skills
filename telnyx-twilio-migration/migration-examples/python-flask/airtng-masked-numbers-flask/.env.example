SECRET_KEY=

SQLALCHEMY_DATABASE_URI=sqlite://survey.sqlite

# Telnyx API credentials
# Get one at https://portal.telnyx.com/#/app/api-keys
export TELNYX_API_KEY=KEYXXXXXXXXXXXXXXXXXXX

# Your Telnyx public key for webhook validation
# Get from https://portal.telnyx.com/#/app/account/public-key
export TELNYX_PUBLIC_KEY=XXXXXXXXXXXXXXXXXXXX

# Telnyx phone number (E.164 format)
export TELNYX_PHONE_NUMBER=+XXXXXXXXXXX

# Telnyx Messaging Profile ID
# Create one at https://portal.telnyx.com/#/app/messaging
export TELNYX_MESSAGING_PROFILE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Telnyx Connection ID (for TeXML voice application)
# Create one at https://portal.telnyx.com/#/app/call-control/connections?type=texml
export TELNYX_CONNECTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
