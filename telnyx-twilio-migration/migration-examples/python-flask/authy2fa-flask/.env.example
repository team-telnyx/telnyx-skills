# Environment variables for authy2fa-flask

# Secret key (used for sessions)
SECRET_KEY=not-so-secret

# Authy API Key (required for OneTouch push notifications)
# Found at https://dashboard.authy.com under your application
AUTHY_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telnyx API Key (required for SMS verification)
# Get from https://portal.telnyx.com/#/app/api-keys
TELNYX_API_KEY=KEYXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Telnyx Verify Profile ID (required for SMS verification)
# Create at https://portal.telnyx.com/#/app/verify-profiles
TELNYX_VERIFY_PROFILE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
