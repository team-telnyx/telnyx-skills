# Environment variables for the Call Tracking Django app

# Django settings to use in this environment
export DJANGO_SETTINGS_MODULE=twilio_sample_project.settings.production

# Telnyx API credentials
export TELNYX_API_KEY=YOUR_TELNYX_API_KEY

# Telnyx Connection ID for voice (TeXML Application)
# Create one at https://portal.telnyx.com/#/app/voice/texml
export TELNYX_CONNECTION_ID=YOUR_CONNECTION_ID

# Telnyx Webhook Public Key for signature validation (optional but recommended)
# Found in portal.telnyx.com -> Developers -> Public Key
export TELNYX_PUBLIC_KEY=YOUR_PUBLIC_KEY
