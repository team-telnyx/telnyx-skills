{
  "name": "@telnyx/agent-cli",
  "version": "0.1.0",
  "description": "Agent-friendly CLI for Telnyx API v2 — composite setup commands that reduce multi-step workflows to a single command",
  "type": "module",
  "bin": {
    "telnyx-agent": "./bin/telnyx-agent.ts"
  },
  "scripts": {
    "start": "tsx bin/telnyx-agent.ts",
    "test": "tsx --test tests/integration.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "tsx": "^4.19.0"
  },
  "peerDependencies": {
    "@telnyx/api-cli": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@telnyx/api-cli": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "telnyx",
    "agent",
    "cli",
    "telecom",
    "sms",
    "voice",
    "iot",
    "10dlc",
    "wireguard"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/team-telnyx/telnyx-agent-portal.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/team-telnyx/telnyx-agent-portal#readme",
  "bugs": {
    "url": "https://github.com/team-telnyx/telnyx-agent-portal/issues"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ]
}
